# Copy this file to .env.local and fill in your own Supabase project values.
# Get these from: Supabase Dashboard → your project → Project Settings → API Keys
#
# NEXT_PUBLIC_SUPABASE_URL is your project's API URL (e.g. https://abcdefgh.supabase.co)
#
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is the new "publishable" key
# (starts with sb_publishable_...). If your Supabase project still shows the
# older key names, use the "anon" / "anon public" key instead — it works the
# same way with this variable name.
#
# If these are left blank, the app still works using browser localStorage
# only (per-device, no cross-device sync) — it just won't have its data
# synced through Supabase.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
